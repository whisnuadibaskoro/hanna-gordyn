<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="#4A2511">
    <title>Admin Login - Hanna Gordyn</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        /* Login page styling */
        body {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        #content {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 20px;
        }

        .login-box {
            width: min(90%, 420px);
            background: rgba(255, 255, 255, 0.06);
            -webkit-backdrop-filter: blur(20px);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(212, 165, 116, 0.3);
            border-radius: 20px;
            padding: 50px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
            position: relative;
            z-index: 1;
        }

        .login-header {
            text-align: center;
            margin-bottom: 40px;
        }

        .login-header .logo {
            font-size: 32px;
            font-weight: 700;
            background: linear-gradient(135deg, #D4A574, #A0522D);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 10px;
            letter-spacing: 2px;
        }

        .login-header p {
            font-size: 13px;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: rgba(255, 255, 255, 0.6);
        }

        .login-box form {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .form-group {
            display: flex;
            flex-direction: column;
        }

        .form-group label {
            display: block;
            color: #D4A574;
            font-size: 12px;
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 600;
        }

        .form-group input {
            padding: 14px 16px;
            border: 2px solid rgba(212, 165, 116, 0.2);
            border-radius: 10px;
            background: rgba(255, 255, 255, 0.06);
            -webkit-backdrop-filter: blur(20px);
            backdrop-filter: blur(20px);
            color: #ffffff;
            font-size: 15px;
            transition: all 0.3s ease;
            -webkit-appearance: none;
            appearance: none;
            min-height: 44px;
        }

        .form-group input::placeholder {
            color: rgba(255, 255, 255, 0.4);
        }

        .form-group input:focus {
            outline: none;
            background: rgba(255, 255, 255, 0.08);
            border-color: rgba(212, 165, 116, 0.6);
            box-shadow: 0 8px 24px rgba(160, 82, 45, 0.3);
        }

        .login-box button {
            width: 100%;
            padding: 14px;
            margin-top: 10px;
            background: linear-gradient(135deg, #A0522D, #D4A574);
            color: white;
            border: 2px solid #D4A574;
            border-radius: 10px;
            cursor: pointer;
            font-size: 15px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: all 0.3s ease;
            box-shadow: 0 8px 24px rgba(160, 82, 45, 0.4);
            -webkit-appearance: none;
            appearance: none;
            min-height: 44px;
        }

        .login-box button:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 32px rgba(160, 82, 45, 0.5);
            background: linear-gradient(135deg, #D4A574, #A0522D);
        }

        .login-box button:active {
            transform: translateY(-2px);
        }

        .login-divider {
            margin: 30px 0;
            padding-top: 30px;
            border-top: 1px solid rgba(212, 165, 116, 0.2);
            text-align: center;
            font-size: 12px;
            color: rgba(255, 255, 255, 0.5);
        }

        .back-link {
            display: block;
            text-align: center;
            color: #D4A574;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .back-link:hover {
            color: #F5E6D3;
            text-decoration: underline;
        }

        footer {
            margin-top: auto;
        }

        @media (max-width: 768px) {
            .login-box {
                width: calc(100% - 40px);
                padding: 30px 20px;
            }

            .login-header .logo {
                font-size: 24px;
            }

            .form-group input,
            .login-box button {
                font-size: 16px;
            }
        }
    </style>
</head>
<body>
<header>
    <div class="logo">HANNA GORDYN</div>
    <nav>
        <a href="/">Beranda</a>
    </nav>
</header>

<div id="loading" class="loading">
    <div class="spinner"></div>
</div>

<div id="content">
    <div class="login-box">
        <div class="login-header">
            <div class="logo">HANNA GORDYN</div>
            <p>Admin Portal</p>
        </div>

        <form action="/admin/login" method="POST">
            <div class="form-group">
                <label for="username">Username</label>
                <input 
                    type="text"
                    id="username"
                    name="username"
                    placeholder="Masukkan username..."
                    required
                    autocomplete="username">
            </div>

            <div class="form-group">
                <label for="password">Password</label>
                <input 
                    type="password"
                    id="password"
                    name="password"
                    placeholder="Masukkan password..."
                    required
                    autocomplete="current-password">
            </div>

            <button type="submit">🔐 Login</button>
        </form>

        <div class="login-divider">
            © 2026 Hanna Gordyn Admin
        </div>
    </div>
</div>

<footer>
    <h2>HANNA GORDYN</h2>
    <p>Gordyn Berkualitas • Garansi Terpercaya • Layanan Terbaik</p>
    <p>© 2026 Hanna Gordyn. All rights reserved.</p>
</footer>
</body>
</html>