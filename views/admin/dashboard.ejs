<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="#4A2511">
    <title>Dashboard Admin - Hanna Gordyn</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        /* Dashboard page styling */
        body {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        #content {
            flex: 1;
            padding: 60px 40px;
        }

        .dashboard-header {
            text-align: center;
            margin-bottom: 50px;
        }

        .dashboard-header h1 {
            font-size: 36px;
            font-weight: 700;
            background: linear-gradient(135deg, #D4A574, #ffffff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin: 0;
            letter-spacing: 1px;
        }

        .dashboard-stats {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-bottom: 50px;
        }

        .stat-card {
            background: rgba(255, 255, 255, 0.06);
            -webkit-backdrop-filter: blur(20px);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(212, 165, 116, 0.3);
            border-radius: 15px;
            padding: 30px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
            text-align: center;
            transition: all 0.3s ease;
            position: relative;
            z-index: 1;
        }

        .stat-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 12px 48px rgba(160, 82, 45, 0.3);
            border-color: rgba(212, 165, 116, 0.5);
        }

        .stat-card .label {
            font-size: 13px;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: rgba(255, 255, 255, 0.6);
            margin-bottom: 15px;
        }

        .stat-card .value {
            font-size: 42px;
            font-weight: 700;
            background: linear-gradient(135deg, #D4A574, #A0522D);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .dashboard-controls {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            gap: 20px;
            flex-wrap: wrap;
        }

        .search-box {
            display: flex;
            gap: 10px;
            flex: 1;
            min-width: 250px;
        }

        .search-box input {
            flex: 1;
            padding: 12px 16px;
            border: 2px solid rgba(212, 165, 116, 0.2);
            border-radius: 10px;
            background: rgba(255, 255, 255, 0.06);
            -webkit-backdrop-filter: blur(20px);
            backdrop-filter: blur(20px);
            color: #ffffff;
            font-size: 15px;
            transition: all 0.3s ease;
            min-height: 44px;
        }

        .search-box input::placeholder {
            color: rgba(255, 255, 255, 0.4);
        }

        .search-box input:focus {
            outline: none;
            background: rgba(255, 255, 255, 0.08);
            border-color: rgba(212, 165, 116, 0.6);
        }

        .search-box button {
            padding: 12px 24px;
            background: linear-gradient(135deg, #A0522D, #D4A574);
            color: white;
            border: 2px solid #D4A574;
            border-radius: 10px;
            cursor: pointer;
            font-size: 14px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: all 0.3s ease;
            box-shadow: 0 8px 24px rgba(160, 82, 45, 0.4);
            min-height: 44px;
        }

        .search-box button:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 28px rgba(160, 82, 45, 0.5);
        }

        .add-button {
            padding: 12px 24px;
            background: linear-gradient(135deg, #D4A574, #A0522D);
            color: white;
            border: 2px solid #D4A574;
            border-radius: 10px;
            text-decoration: none;
            font-size: 14px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: all 0.3s ease;
            box-shadow: 0 8px 24px rgba(160, 82, 45, 0.4);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 44px;
            white-space: nowrap;
        }

        .add-button:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 28px rgba(160, 82, 45, 0.5);
        }

        .table-container {
            overflow-x: auto;
            background: rgba(255, 255, 255, 0.06);
            -webkit-backdrop-filter: blur(20px);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(212, 165, 116, 0.3);
            border-radius: 15px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
            padding: 20px;
            position: relative;
            z-index: 1;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        table th {
            background: linear-gradient(135deg, #A0522D, #D4A574);
            color: white;
            padding: 15px 12px;
            text-align: left;
            font-size: 13px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            border-bottom: 2px solid rgba(212, 165, 116, 0.3);
        }

        table td {
            padding: 15px 12px;
            border-bottom: 1px solid rgba(212, 165, 116, 0.1);
            color: #ffffff;
            font-size: 14px;
        }

        table tr:hover {
            background: rgba(212, 165, 116, 0.05);
        }

        .receipt-badge {
            background: linear-gradient(135deg, #A0522D, #D4A574);
            color: white;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            letter-spacing: 0.5px;
            display: inline-block;
        }

        .warranty-active {
            color: #4ADE80;
            font-weight: 600;
        }

        .warranty-expired {
            color: #ff6b6b;
            font-weight: 600;
        }

        .action-buttons {
            display: flex;
            gap: 8px;
        }

        .btn-edit, .btn-delete {
            padding: 6px 12px;
            border-radius: 6px;
            text-decoration: none;
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            transition: all 0.3s ease;
            display: inline-block;
            min-height: 32px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            border: 2px solid;
        }

        .btn-edit {
            background: rgba(74, 222, 128, 0.1);
            color: #4ADE80;
            border-color: rgba(74, 222, 128, 0.3);
        }

        .btn-edit:hover {
            background: rgba(74, 222, 128, 0.2);
            border-color: #4ADE80;
        }

        .btn-delete {
            background: rgba(255, 107, 107, 0.1);
            color: #ff6b6b;
            border-color: rgba(255, 107, 107, 0.3);
        }

        .btn-delete:hover {
            background: rgba(255, 107, 107, 0.2);
            border-color: #ff6b6b;
        }

        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: rgba(255, 255, 255, 0.5);
        }

        .empty-state p {
            font-size: 16px;
            margin-bottom: 20px;
        }

        .empty-state a {
            display: inline-block;
            padding: 12px 24px;
            background: linear-gradient(135deg, #D4A574, #A0522D);
            color: white;
            border: 2px solid #D4A574;
            border-radius: 10px;
            text-decoration: none;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: all 0.3s ease;
            min-height: 44px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .empty-state a:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(160, 82, 45, 0.4);
        }

        footer {
            margin-top: auto;
        }

        @media (max-width: 768px) {
            #content {
                padding: 20px;
            }

            .dashboard-header h1 {
                font-size: 28px;
            }

            .dashboard-controls {
                flex-direction: column;
                gap: 15px;
            }

            .search-box {
                width: 100%;
            }

            .add-button {
                width: 100%;
            }

            table {
                font-size: 12px;
            }

            table th,
            table td {
                padding: 10px 8px;
            }

            .action-buttons {
                flex-direction: column;
            }

            .btn-edit, .btn-delete {
                width: 100%;
            }
        }
    </style>
</head>
<body>
<header>
    <div class="logo">HANNA GORDYN</div>
    <nav>
        <a href="/">Beranda</a>
        <a href="/admin/logout">Logout</a>
    </nav>
</header>

<div id="loading" class="loading">
    <div class="spinner"></div>
</div>

<div id="content">
    <div class="dashboard-header">
        <h1>📊 Dashboard Admin</h1>
    </div>

    <div class="dashboard-stats">
        <div class="stat-card">
            <div class="label">Total Garansi</div>
            <div class="value"><%= data.length %></div>
        </div>
        <div class="stat-card">
            <div class="label">Garansi Aktif</div>
            <div class="value"><%= data.filter(item => new Date(item.warranty_end) > new Date()).length %></div>
        </div>
        <div class="stat-card">
            <div class="label">Garansi Kadaluarsa</div>
            <div class="value"><%= data.filter(item => new Date(item.warranty_end) <= new Date()).length %></div>
        </div>
    </div>

    <div class="dashboard-controls">
        <form action="/admin/search" method="GET" class="search-box">
            <input
                type="text"
                name="keyword"
                placeholder="🔍 Cari nama pembeli..."
                autocomplete="off">
            <button type="submit">Cari</button>
        </form>
        <a href="/admin/tambah" class="add-button">➕ Tambah Garansi</a>
    </div>

    <div class="table-container">
        <% if(data.length === 0) { %>
            <div class="empty-state">
                <p>📭 Belum ada data garansi. Mulai dengan menambahkan data pertama.</p>
                <a href="/admin/tambah">➕ Tambah Data Garansi</a>
            </div>
        <% } else { %>
            <table>
                <thead>
                    <tr>
                        <th>No</th>
                        <th>Nama Pembeli</th>
                        <th>No Resi</th>
                        <th>Tipe Garansi</th>
                        <th>Tgl Pembelian</th>
                        <th>Berlaku Sampai</th>
                        <th>Aksi</th>
                    </tr>
                </thead>
                <tbody>
                    <% data.forEach((item, index) => { %>
                        <tr>
                            <td><%= index + 1 %></td>
                            <td><%= item.buyer_name %></td>
                            <td><span class="receipt-badge"><%= item.receipt_number %></span></td>
                            <td><%= item.warranty_type %></td>
                            <td><%= new Date(item.purchase_date).toLocaleDateString('id-ID', { year: 'numeric', month: 'short', day: 'numeric' }) %></td>
                            <td style="<%= new Date(item.warranty_end) > new Date() ? 'color: #4ADE80' : 'color: #ff6b6b' %>">
                                <%= new Date(item.warranty_end).toLocaleDateString('id-ID', { year: 'numeric', month: 'short', day: 'numeric' }) %>
                            </td>
                            <td>
                                <div class="action-buttons">
                                    <a href="/admin/edit/<%= item.id %>" class="btn-edit">✏️ Edit</a>
                                    <a href="/admin/hapus/<%= item.id %>" class="btn-delete" onclick="return confirm('Yakin ingin menghapus data ini?')">🗑️ Hapus</a>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        <% } %>
    </div>
</div>

<footer>
    <h2>HANNA GORDYN</h2>
    <p>Gordyn Berkualitas • Garansi Terpercaya • Layanan Terbaik</p>
    <p>© 2026 Hanna Gordyn. All rights reserved.</p>
</footer>
</body>
</html>