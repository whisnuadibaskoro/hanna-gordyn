<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="#4A2511">
    <title>Admin Dashboard - Hanna Gordyn</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        /* Admin-specific enhancements */
        .admin-header {
            background: rgba(74, 37, 17, 0.5);
            -webkit-backdrop-filter: blur(20px);
            backdrop-filter: blur(20px);
            border-bottom: 2px solid rgba(212, 165, 116, 0.3);
            padding: 20px 60px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 40px;
            border-radius: 0 0 20px 20px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
        }

        .admin-header h1 {
            font-size: 32px;
            font-weight: 700;
            background: linear-gradient(135deg, #D4A574, #A0522D);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin: 0;
        }

        .admin-header .user-info {
            display: flex;
            align-items: center;
            gap: 15px;
            font-size: 14px;
            color: rgba(255, 255, 255, 0.8);
        }

        .admin-header .user-info a {
            padding: 8px 16px;
            background: linear-gradient(135deg, #A0522D, #D4A574);
            color: white;
            border: 2px solid #D4A574;
            border-radius: 8px;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s ease;
            min-height: 44px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .admin-header .user-info a:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(160, 82, 45, 0.4);
        }

        .admin-stats {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-bottom: 40px;
            padding: 0 60px;
        }

        .stat-card {
            background: rgba(255, 255, 255, 0.06);
            -webkit-backdrop-filter: blur(20px);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(212, 165, 116, 0.2);
            border-radius: 15px;
            padding: 20px;
            text-align: center;
            transition: all 0.3s ease;
        }

        .stat-card:hover {
            background: rgba(255, 255, 255, 0.08);
            border-color: rgba(212, 165, 116, 0.4);
            transform: translateY(-4px);
        }

        .stat-number {
            font-size: 32px;
            font-weight: 700;
            background: linear-gradient(135deg, #D4A574, #A0522D);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 8px;
        }

        .stat-label {
            font-size: 13px;
            color: rgba(255, 255, 255, 0.7);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .admin-controls {
            display: flex;
            gap: 15px;
            margin-bottom: 30px;
            padding: 0 60px;
            flex-wrap: wrap;
        }

        .admin-controls a {
            padding: 12px 24px;
            background: linear-gradient(135deg, #A0522D, #D4A574);
            color: white;
            border: 2px solid #D4A574;
            border-radius: 10px;
            text-decoration: none;
            font-weight: 600;
            font-size: 14px;
            transition: all 0.3s ease;
            min-height: 44px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 6px 20px rgba(160, 82, 45, 0.3);
        }

        .admin-controls a:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 28px rgba(160, 82, 45, 0.4);
            background: linear-gradient(135deg, #D4A574, #A0522D);
        }

        .table-wrapper {
            padding: 0 60px 60px;
            overflow-x: auto;
        }

        .admin table {
            width: 100%;
            border-collapse: collapse;
            background: rgba(255, 255, 255, 0.04);
            -webkit-backdrop-filter: blur(20px);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(212, 165, 116, 0.2);
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
        }

        .admin thead {
            background: linear-gradient(135deg, rgba(160, 82, 45, 0.3), rgba(212, 165, 116, 0.2));
            border-bottom: 2px solid rgba(212, 165, 116, 0.3);
        }

        .admin th {
            color: #D4A574;
            padding: 18px 20px;
            text-align: left;
            font-weight: 700;
            font-size: 13px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .admin td {
            padding: 16px 20px;
            border-bottom: 1px solid rgba(212, 165, 116, 0.1);
            color: rgba(255, 255, 255, 0.9);
            font-size: 14px;
        }

        .admin tbody tr {
            transition: all 0.3s ease;
        }

        .admin tbody tr:hover {
            background: rgba(212, 165, 116, 0.1);
        }

        .admin tbody tr:hover td {
            color: #D4A574;
        }

        .receipt-badge {
            background: rgba(212, 165, 116, 0.2);
            padding: 6px 12px;
            border-radius: 8px;
            font-weight: 600;
            border: 1px solid rgba(212, 165, 116, 0.3);
            display: inline-block;
        }

        .warranty-active {
            color: #4ADE80;
            font-weight: 600;
        }

        .warranty-expired {
            color: #ff6b6b;
            font-weight: 600;
        }

        .action-delete {
            color: #ff6b6b;
            text-decoration: none;
            font-weight: 600;
            padding: 6px 12px;
            border-radius: 6px;
            transition: all 0.3s ease;
            display: inline-block;
        }

        .action-delete:hover {
            background: rgba(255, 107, 107, 0.2);
            border: 1px solid rgba(255, 107, 107, 0.3);
        }

        .empty-state {
            text-align: center;
            padding: 80px 60px;
            color: rgba(255, 255, 255, 0.6);
        }

        .empty-state-icon {
            font-size: 64px;
            margin-bottom: 20px;
        }

        .empty-state p {
            font-size: 18px;
            margin-bottom: 30px;
            color: rgba(255, 255, 255, 0.7);
        }

        .empty-state .btn {
            display: inline-block;
            padding: 12px 32px;
            background: linear-gradient(135deg, #A0522D, #D4A574);
            color: white;
            border: 2px solid #D4A574;
            border-radius: 10px;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s ease;
            box-shadow: 0 6px 20px rgba(160, 82, 45, 0.3);
        }

        .empty-state .btn:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 28px rgba(160, 82, 45, 0.4);
            background: linear-gradient(135deg, #D4A574, #A0522D);
        }

        @media (max-width: 768px) {
            .admin-header {
                padding: 15px 20px;
                flex-direction: column;
                gap: 15px;
                text-align: center;
            }

            .admin-header h1 {
                font-size: 24px;
            }

            .admin-stats {
                padding: 0 20px;
                grid-template-columns: 1fr;
            }

            .admin-controls {
                padding: 0 20px;
                flex-direction: column;
            }

            .admin-controls a {
                width: 100%;
            }

            .table-wrapper {
                padding: 0 20px 40px;
            }

            .admin table {
                font-size: 12px;
            }

            .admin th,
            .admin td {
                padding: 12px 10px;
            }

            .empty-state {
                padding: 40px 20px;
            }
        }
    </style>
</head>
<body>
<header>
    <div class="logo">HANNA GORDYN</div>
    <nav>
        <a href="/">🏠 Beranda</a>
        <a href="/#katalog">📦 Katalog</a>
        <a href="/#garansi">✅ Garansi</a>
        <a href="/#kontak">💬 Kontak</a>
    </nav>
</header>

<div id="loading" class="loading">
    <div class="spinner"></div>
</div>

<div id="content">
    <div class="admin-header">
        <h1>📊 Dashboard Admin</h1>
        <div class="user-info">
            <span>👤 Admin Panel</span>
            <a href="/admin/logout" onclick="return confirm('Yakin ingin logout?');">🚪 Logout</a>
        </div>
    </div>

    <% if (data.length > 0) { %>
    <div class="admin-stats">
        <div class="stat-card">
            <div class="stat-number"><%= data.length %></div>
            <div class="stat-label">Total Garansi</div>
        </div>
        <div class="stat-card">
            <div class="stat-number">
                <%= data.filter(item => new Date(item.warranty_end) > new Date()).length %>
            </div>
            <div class="stat-label">Garansi Aktif</div>
        </div>
        <div class="stat-card">
            <div class="stat-number">
                <%= data.filter(item => new Date(item.warranty_end) <= new Date()).length %>
            </div>
            <div class="stat-label">Garansi Kadaluarsa</div>
        </div>
    </div>
    <% } %>

    <div class="admin-controls">
        <a href="/admin/tambah" title="Tambah data garansi baru">➕ Tambah Garansi Baru</a>
        <a href="/admin/dashboard" style="background: rgba(212, 165, 116, 0.1); border-color: rgba(212, 165, 116, 0.3);">🔄 Refresh</a>
    </div>

    <% if (data.length > 0) { %>
    <div class="table-wrapper">
        <div class="admin">
            <table>
                <thead>
                    <tr>
                        <th>No.</th>
                        <th>Nama Pembeli</th>
                        <th>Nomor Resi</th>
                        <th>Tipe Garansi</th>
                        <th>Tgl Pembelian</th>
                        <th>Tgl Kadaluarsa</th>
                        <th>Aksi</th>
                    </tr>
                </thead>
                <tbody>
                    <% data.forEach((item, index) => { %>
                    <tr>
                        <td><strong><%= index + 1 %></strong></td>
                        <td><%= item.buyer_name %></td>
                        <td><span class="receipt-badge"><%= item.receipt_number %></span></td>
                        <td><%= item.warranty_type %></td>
                        <td><%= new Date(item.purchase_date).toLocaleDateString('id-ID') %></td>
                        <td>
                            <strong class="<%= new Date(item.warranty_end) < new Date() ? 'warranty-expired' : 'warranty-active' %>">
                                <%= new Date(item.warranty_end).toLocaleDateString('id-ID') %>
                            </strong>
                        </td>
                        <td>
                            <a href="/admin/hapus/<%= item.id %>" onclick="return confirm('Yakin hapus data ini?');" class="action-delete">🗑️ Hapus</a>
                        </td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    </div>
    <% } else { %>
    <div class="empty-state">
        <div class="empty-state-icon">📭</div>
        <p>Belum ada data garansi tersimpan</p>
        <a href="/admin/tambah" class="btn">➕ Tambah Data Garansi Pertama</a>
    </div>
    <% } %>
</div>

<footer>
    <h2>HANNA GORDYN</h2>
    <p>Gordyn Berkualitas • Garansi Terpercaya • Layanan Terbaik</p>
    <p>© 2026 Hanna Gordyn. All rights reserved.</p>
</footer>

<script>
    // AJAX navigation for admin links
    document.querySelectorAll('nav a, .admin-controls a').forEach(link => {
        if (!link.hasAttribute('onclick') && link.href !== window.location.href) {
            link.addEventListener('click', function(e) {
                if (link.hostname !== window.location.hostname) return;
                e.preventDefault();
                
                const url = this.href;
                document.getElementById('loading').classList.add('show');
                
                fetch(url)
                    .then(res => res.text())
                    .then(html => {
                        const parser = new DOMParser();
                        const doc = parser.parseFromString(html, 'text/html');
                        const newContent = doc.querySelector('#content');
                        
                        if (newContent) {
                            document.getElementById('content').innerHTML = newContent.innerHTML;
                            window.history.pushState({}, '', url);
                            setTimeout(() => document.getElementById('loading').classList.remove('show'), 300);
                            window.scrollTo(0, 0);
                        }
                    })
                    .catch(err => {
                        console.error('Error:', err);
                        window.location.href = url;
                    });
            });
        }
    });
</script>
</body>
</html>