<%- include('partials/header') %>

<section class="hero">

    <h1>AI Interior Consultant</h1>

    <p>
        Upload foto ruangan Anda dan
        dapatkan rekomendasi produk
        Hanna Gordyn secara otomatis.
    </p>

    <form
        action="/rekomendasi"
        method="POST"
        enctype="multipart/form-data">

        <input
            type="file"
            name="foto"
            accept="image/*"
            required>

        <button type="submit">
            Analisis Ruangan
        </button>

    </form>

    <% if(error){ %>
        <div class="error-box">
            <h3>Error</h3>
            <p><%= error %></p>
        </div>
    <% } %>

    <% if(hasil){ %>
        <div class="hasil-box">
            <h2>Hasil Analisis AI</h2>

            <pre><%= hasil %></pre>

        </div>
    <% } %>

</section>

<%- include('partials/footer') %>